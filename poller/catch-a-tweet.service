[Unit]
Description=catch-a-tweet — X account watcher and Telegram alerter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=azureuser
WorkingDirectory=/home/azureuser/libs/catch-a-tweet/poller
Environment=PYTHONPATH=/home/azureuser/libs/catch-a-tweet/poller/src
EnvironmentFile=/home/azureuser/libs/catch-a-tweet/poller/.env
ExecStart=/home/azureuser/libs/catch-a-tweet/poller/.venv/bin/python src/runner.py
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
